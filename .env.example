# ── Environment variables ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

SECRET_KEY=school-portal-super-secret-key-change-this

DEBUG=True

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=school_portal

# ── Storage (S3 / Railway Bucket) ──────────────────────────
# Set to 's3' to use Railway Bucket, or 'local' for local static files
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_BUCKET_NAME=school-images
AWS_REGION=us-east-1
# Only if using Railway Minio or other local S3
# AWS_ENDPOINT_URL_S3=https://...
